{% set t = i18n[lang] %}
<header class="site-header">
  <div class="container header-inner">
    <a class="logo" href="{{ langmeta[lang].home | url }}">
      <svg class="logo-sun" viewBox="0 0 24 24" width="22" height="22" aria-hidden="true"><circle cx="12" cy="12" r="5" fill="currentColor"/><g stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="12" y1="1" x2="12" y2="4"/><line x1="12" y1="20" x2="12" y2="23"/><line x1="4.2" y1="4.2" x2="6.3" y2="6.3"/><line x1="17.7" y1="17.7" x2="19.8" y2="19.8"/><line x1="1" y1="12" x2="4" y2="12"/><line x1="20" y1="12" x2="23" y2="12"/><line x1="4.2" y1="19.8" x2="6.3" y2="17.7"/><line x1="17.7" y1="6.3" x2="19.8" y2="4.2"/></g></svg>
      <span>Good&nbsp;Vibes</span>
    </a>
    <nav class="main-nav" id="main-nav">
      <a href="{{ langmeta[lang].home | url }}#apartments">{{ t.nav.apartments }}</a>
      <a href="{{ langmeta[lang].home | url }}#owners">{{ t.nav.owners }}</a>
      <a href="{{ langmeta[lang].home | url }}#contact">{{ t.nav.contact }}</a>
      <a href="{{ '/blog/' | url }}">{{ t.nav.blog }}</a>
    </nav>
    <div class="lang-switcher">
      {%- for l in site.langs %}
      <a href="{{ (altUrls[l] if altUrls and altUrls[l] else langmeta[l].home) | url }}" class="{{ 'active' if l == lang }}" lang="{{ l }}" aria-label="{{ i18n[l].langName }}">{{ l | upper }}</a>
      {%- endfor %}
    </div>
    <button class="nav-toggle" aria-label="Menu" aria-expanded="false" data-nav-toggle>
      <span></span><span></span><span></span>
    </button>
  </div>
</header>
