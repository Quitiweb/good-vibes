---
pagination:
  data: site.langs
  size: 1
  alias: lang
  addAllPagesToCollections: true
permalink: "{% if lang == 'es' %}/blog/index.html{% else %}/{{ lang }}/blog/index.html{% endif %}"
layout: layouts/base.njk
eleventyComputed:
  pageTitle: "Blog — Good Vibes Apartments"
  pageDesc: "Guides and tips for guests and owners of holiday apartments in Malaga."
  altUrls:
    es: "/blog/"
    en: "/en/blog/"
    fr: "/fr/blog/"
    it: "/it/blog/"
---
{% set t = i18n[lang] %}
<section class="section">
  <div class="container">
    <h1>{{ t.blog.title }}</h1>
    <p class="section-sub">{{ t.blog.subtitle }}</p>
    <div class="blog-list">
      {%- for post in collections.posts | reverse %}
        {%- if post.data.lang == lang %}
      <article class="blog-card">
        <h3><a href="{{ post.url | url }}">{{ post.data.title }}</a></h3>
        <p class="blog-meta">{{ post.date | readableDate(lang) }} · Good Vibes Apartments</p>
        <p>{{ post.data.description }}</p>
        <a href="{{ post.url | url }}">{{ t.blog.readMore }} →</a>
      </article>
        {%- endif %}
      {%- endfor %}
    </div>
  </div>
</section>
